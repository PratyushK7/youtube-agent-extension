{
  "manifest_version": 3,
  "name": "YT Research Dossier Agent",
  "version": "1.1",
  "description": "Professional-grade YouTube research agent that builds comprehensive strategic dossiers.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.chatgpt.com/*",
    "http://localhost:3005/*",
    "http://127.0.0.1:3005/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content_youtube.js", "content_youtube_player.js"],
      "css": ["content_youtube.css"]
    },
    {
      "matches": ["https://*.chatgpt.com/*"],
      "js": ["content_chatgpt.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
